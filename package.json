    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "fetch:tweet": "node scripts/fetch-tweet.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
