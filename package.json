    "@fontsource/newsreader": "^5.2.10",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@supabase/supabase-js": "^2.107.0",
    "@unhead/react": "^3.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.17.0",
    "react-tweet": "^3.3.1",
