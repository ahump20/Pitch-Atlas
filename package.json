{
  "name": "pitch-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A sourced, interactive reference for how pitches are gripped and thrown. Sourced, not corrected.",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
