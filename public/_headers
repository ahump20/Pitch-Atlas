/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(self "https://streamable.com"), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'sha256-gOx3nRh8znDQR7T1VkI+fFXDgsNzf5enQqdi7NP11Vk=' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://pbs.twimg.com https://abs.twimg.com https://*.supabase.co; media-src 'self' blob: https://video.twimg.com https://*.supabase.co; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cloudflareinsights.com; frame-src https://streamable.com; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests
  ! Access-Control-Allow-Origin

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/brand/anton-latin-400.woff2
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-store

# Static, deploy-versioned artifacts. They change only on deploy, so a day-long
# edge cache spares crawlers and repeat visitors a needless revalidation. The
# sitemap is a hint and every route resolves directly regardless, so staleness is
# harmless; stale-while-revalidate keeps it fresh right after a deploy.
/sitemap.xml
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/robots.txt
  Cache-Control: public, max-age=86400

/og-image.png
  Cache-Control: public, max-age=86400

/og/*
  Cache-Control: public, max-age=86400

/site.webmanifest
  Cache-Control: public, max-age=86400
